# ============================================================================
# SUPABASE (Database & Auth)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# For local development
SUPABASE_LOCAL_URL=http://localhost:54321
SUPABASE_LOCAL_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# ORGANIZATION & DEPLOYMENT
# ============================================================================
ORG_ID=00000000-0000-0000-0000-000000000000
APP_BASE_URL=https://app.reviewprepengine.com
ENVIRONMENT=production
# Values: development, staging, production

# ============================================================================
# CRM: SALESFORCE
# ============================================================================
SALESFORCE_INSTANCE_URL=https://your-org.salesforce.com
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret
SALESFORCE_USERNAME=your-salesforce-username
SALESFORCE_PASSWORD=your-salesforce-password
SALESFORCE_SECURITY_TOKEN=your-security-token
# Salesforce custom object API names (if different from defaults)
SALESFORCE_PORTFOLIO_OBJECT=Portfolio__c
SALESFORCE_REVIEW_OBJECT=Review__c
SALESFORCE_BRIEFING_LOG_OBJECT=BriefingLog__c

# ============================================================================
# CUSTODIAN APIS (Investment Account Data)
# ============================================================================
# Schwab
SCHWAB_API_URL=https://api.schwabapi.com
SCHWAB_API_KEY=your-schwab-api-key
SCHWAB_API_SECRET=your-schwab-api-secret
SCHWAB_ACCOUNT_IDS=ABC123,XYZ789
# Comma-separated account IDs to sync

# Fidelity (if applicable)
FIDELITY_API_URL=https://api.fidelity.com
FIDELITY_API_KEY=your-fidelity-api-key
FIDELITY_API_SECRET=your-fidelity-api-secret

# Interactive Brokers (if applicable)
IB_API_URL=https://api.interactivebrokers.com
IB_API_KEY=your-ib-api-key

# ============================================================================
# WORKFLOW AUTOMATION: n8n
# ============================================================================
N8N_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key
# Workflows
N8N_CRM_DAILY_SYNC_WORKFLOW_ID=abc123
N8N_REVIEW_REMINDER_WORKFLOW_ID=def456

# ============================================================================
# ASYNC JOBS: TRIGGER.DEV
# ============================================================================
TRIGGER_API_URL=https://api.trigger.dev
TRIGGER_API_KEY=your-trigger-api-key
TRIGGER_PROJECT_ID=your-project-id
# Job IDs
TRIGGER_BRIEFING_JOB_ID=briefing_generation
TRIGGER_ENGAGEMENT_JOB_ID=engagement_batch

# ============================================================================
# EMAIL: SENDGRID
# ============================================================================
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourcompany.com
SENDGRID_FROM_NAME=Review Prep Engine
SENDGRID_REVIEW_REMINDER_TEMPLATE_ID=d-abc123
SENDGRID_ATTRITION_ALERT_TEMPLATE_ID=d-def456

# ============================================================================
# NOTIFICATIONS & ALERTS
# ============================================================================
OPS_EMAIL=ops@yourcompany.com
COMPLIANCE_EMAIL=compliance@yourcompany.com
SUPPORT_EMAIL=support@yourcompany.com
# Slack integration (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL_ALERTS=#ops-alerts
SLACK_CHANNEL_REPORTS=#business-reports

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET=your-jwt-secret-key-change-in-production
SESSION_SECRET=your-session-secret-key-change-in-production
# OAuth providers for admin UI
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=info
# Values: debug, info, warn, error
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_BRIEFING_GENERATION=true
ENABLE_ENGAGEMENT_SCORING=true
ENABLE_CRM_SYNC=true
ENABLE_CUSTODIAN_SYNC=true
ENABLE_ATTRITION_ALERTS=true
ENABLE_EMAIL_NOTIFICATIONS=true

# ============================================================================
# PERFORMANCE & LIMITS
# ============================================================================
# Max households to process per workflow run
MAX_HOUSEHOLDS_PER_RUN=1000
# Max positions to process per household
MAX_POSITIONS_PER_ACCOUNT=500
# Sync timeout (seconds)
SYNC_TIMEOUT_SECONDS=300
# Briefing generation timeout (seconds)
BRIEFING_TIMEOUT_SECONDS=60
# Email rate limiting (requests per minute)
EMAIL_RATE_LIMIT=100

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
DEBUG=false
MOCK_SALESFORCE_API=false
MOCK_CUSTODIAN_API=false
# Use local n8n instance
N8N_LOCAL_MODE=false
